# boating-accident configuration — copy to .env and adjust. All settings are optional.

# Listen address.
BOAT_ADDR=:8080

# Directory for the SQLite database and encrypted uploads.
BOAT_DATA_DIR=./data

# Dev mode relaxes the Secure cookie flag so auth works over http://localhost.
# DO NOT enable in production (HTTPS).
BOAT_DEV=false

# Argon2id KDF cost, applied only when a NEW vault is created. Higher = stronger
# against offline PIN brute-force, but a slower unlock.
BOAT_ARGON2_MEMORY_MB=256
BOAT_ARGON2_TIME=4
BOAT_ARGON2_THREADS=4

